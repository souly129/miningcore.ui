<!-- Enhanced Scripts with Mobile Support -->
<script>
// Theme Management
function toggleTheme() {
  const body = document.body;
  const currentTheme = body.getAttribute('data-theme');
  const newTheme = currentTheme === 'dark' ? 'light' : 'dark';

  body.setAttribute('data-theme', newTheme);
  localStorage.setItem('theme', newTheme);

  // Update theme icon
  document.getElementById('themeIcon').textContent = newTheme === 'dark' ? '🌙' : '☀️';
  
  // Update all charts with new theme colors
  updateChartTheme();
}

// Update chart theme colors
function updateChartTheme() {
  const isDark = document.body.getAttribute('data-theme') === 'dark';
  
  // Update CSS variables
  const root = document.documentElement;
  const computedStyle = getComputedStyle(root);
  
  // Update all Chart.js instances
  Object.keys(window.chartInstances || {}).forEach(chartId => {
    const chart = window.chartInstances[chartId];
    if (chart) {
      // Update chart colors based on theme
      updateChartColors(chart, isDark);
      chart.update('none'); // Update without animation
    }
  });
}

// Update chart colors based on theme
function updateChartColors(chart, isDark) {
  const colors = {
    text: isDark ? '#b0b0b0' : '#666666',
    grid: isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)',
    primary: isDark ? '#00d4ff' : '#0099cc',
    success: isDark ? '#00ff88' : '#00cc66',
    warning: isDark ? '#ffaa00' : '#ff9900'
  };
  
  // Update scales
  if (chart.options.scales) {
    Object.values(chart.options.scales).forEach(scale => {
      scale.ticks.color = colors.text;
      scale.grid.color = colors.grid;
    });
  }
  
  // Update tooltip
  if (chart.options.plugins && chart.options.plugins.tooltip) {
    chart.options.plugins.tooltip.backgroundColor = isDark ? 'rgba(26, 26, 26, 0.9)' : 'rgba(255, 255, 255, 0.9)';
    chart.options.plugins.tooltip.titleColor = isDark ? '#ffffff' : '#1a1a1a';
    chart.options.plugins.tooltip.bodyColor = isDark ? '#b0b0b0' : '#666666';
    chart.options.plugins.tooltip.borderColor = isDark ? '#333333' : '#e0e0e0';
  }
}

// Load saved theme
document.addEventListener('DOMContentLoaded', function() {
  const savedTheme = localStorage.getItem('theme') || 'dark';
  document.body.setAttribute('data-theme', savedTheme);
  document.getElementById('themeIcon').textContent = savedTheme === 'dark' ? '🌙' : '☀️';
});

// Mobile Navigation Toggle
function toggleMobileNav() {
  const nav = document.getElementById('main-pool-nav');
  nav.classList.toggle('active');
  
  // Close mobile menu if clicking on nav toggle
  const sidebar = document.getElementById('pool-sidebar');
  if (sidebar && sidebar.classList.contains('active')) {
    sidebar.classList.remove('active');
  }
}

// Mobile Menu Toggle
function toggleMobileMenu() {
  const sidebar = document.getElementById('pool-sidebar');
  sidebar.classList.toggle('active');
  
  // Close mobile nav if clicking on menu toggle
  const nav = document.getElementById('main-pool-nav');
  if (nav && nav.classList.contains('active')) {
    nav.classList.remove('active');
  }
}

// Close mobile menus when clicking outside
document.addEventListener('click', function(event) {
  const nav = document.getElementById('main-pool-nav');
  const navToggle = document.querySelector('.mobile-nav-toggle');
  const sidebar = document.getElementById('pool-sidebar');
  const menuToggle = document.querySelector('.mobile-menu-toggle');
  
  // Close nav if clicking outside
  if (nav && nav.classList.contains('active') && 
      !nav.contains(event.target) && 
      !navToggle.contains(event.target)) {
    nav.classList.remove('active');
  }
  
  // Close sidebar if clicking outside
  if (sidebar && sidebar.classList.contains('active') && 
      !sidebar.contains(event.target) && 
      !menuToggle.contains(event.target)) {
    sidebar.classList.remove('active');
  }
});

// Enhanced Tab Switching
function switchTab(evt, tabName) {
  evt.preventDefault();
  var i, tabcontent, tablinks;

  // Hide all tab content
  tabcontent = document.getElementsByClassName("tab-content");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }

  // Remove active class from all tab links
  tablinks = evt.currentTarget.parentElement.getElementsByClassName("tab-link");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].classList.remove("active");
  }

  // Show selected tab and mark as active
  document.getElementById(tabName).style.display = "block";
  evt.currentTarget.classList.add("active");
  
  // Scroll tab into view on mobile
  if (window.innerWidth <= 768) {
    evt.currentTarget.scrollIntoView({ behavior: 'smooth', inline: 'center' });
  }
}

// Function to handle block tab switching
function switchBlockTab(evt, tabName) {
  evt.preventDefault();
  var i, tabcontent, tablinks;

  // Hide all block tab content
  tabcontent = document.getElementsByClassName("block-tab-content");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }

  // Remove active class from all tab links in blocks section
  tablinks = evt.currentTarget.parentElement.getElementsByClassName("tab-link");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].classList.remove("active");
  }

  // Show selected tab and mark as active
  document.getElementById(tabName).style.display = "block";
  evt.currentTarget.classList.add("active");
  
  // Scroll tab into view on mobile
  if (window.innerWidth <= 768) {
    evt.currentTarget.scrollIntoView({ behavior: 'smooth', inline: 'center' });
  }
}

// Fix navigation for global pages
$(document).on('click', '.nav-help', function(e) {
  e.preventDefault();
  window.location.hash = 'help';
  loadIndex();
  
  // Close mobile menu
  const nav = document.getElementById('main-pool-nav');
  if (nav && nav.classList.contains('active')) {
    nav.classList.remove('active');
  }
});

$(document).on('click', '.nav-about', function(e) {
  e.preventDefault();
  window.location.hash = 'about';
  loadIndex();
  
  // Close mobile menu
  const nav = document.getElementById('main-pool-nav');
  if (nav && nav.classList.contains('active')) {
    nav.classList.remove('active');
  }
});

// Close sidebar on link click (mobile)
$(document).on('click', '.sidebar-menu-link', function() {
  if (window.innerWidth <= 1024) {
    const sidebar = document.getElementById('pool-sidebar');
    if (sidebar && sidebar.classList.contains('active')) {
      sidebar.classList.remove('active');
    }
  }
});

// Initialize page
$(document).ready(function() {

  // Add smooth scrolling
  $('a[href*="#"]').on('click', function(e) {
    if (this.hash !== '') {
      e.preventDefault();
      const hash = this.hash;
      $('html, body').animate({
        scrollTop: 0
      }, 300, function() {
        window.location.hash = hash;
      });
    }
  });
  
  // Add touch event handling for mobile
  if ('ontouchstart' in window) {
    document.body.classList.add('touch-device');
  }
  
  // Handle responsive tables
  addDataLabelsToTables();
});

// Add data labels to tables for mobile card view
function addDataLabelsToTables() {
  // Worker table
  $('#workerList').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Worker ID', 'Hashrate (30m)', 'Hashrate (3h)', 'Best Share', 'Last Share'];
      $(this).attr('data-label', headers[index]);
    });
  });
  
  // Payouts table
  $('#payoutsList').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Time', 'Amount', 'Address', 'Transaction ID'];
      $(this).attr('data-label', headers[index]);
    });
  });
  
  // Earnings table
  $('#EarningsList').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Date', 'Description', 'Amount'];
      $(this).attr('data-label', headers[index]);
    });
  });
  
  // Daily Payment table
  $('#DailyPaymentList').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Date', 'Day', 'Amount', 'Status'];
      $(this).attr('data-label', headers[index]);
    });
  });
  
  // Miners table
  $('#minerList').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Address', 'Hashrate', 'Share Rate', 'Best Share'];
      $(this).attr('data-label', headers[index]);
    });
  });
  
  // Payments table
  $('#paymentList').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Time', 'Address', 'Amount', 'Transaction'];
      $(this).attr('data-label', headers[index]);
    });
  });

  // Best Share Leaderboard table
  $('#bestShareLeaderboard').on('DOMNodeInserted', 'tr', function() {
    $(this).find('td').each(function(index) {
      const headers = ['Rank', 'Miner Address', 'Best Share Difficulty', 'Found'];
      $(this).attr('data-label', headers[index]);
    });
  });
}

// Prevent zoom on input focus (iOS)
$(document).on('touchstart', 'input[type="text"], input[type="email"], input[type="password"], textarea', function() {
  $(this).css('font-size', '16px');
});

// Handle orientation change
window.addEventListener('orientationchange', function() {
  // Adjust layout after orientation change
  setTimeout(function() {
    window.scrollTo(0, 0);
    // Resize charts after orientation change
    Object.values(window.chartInstances || {}).forEach(chart => {
      if (chart) {
        chart.resize();
      }
    });
  }, 300);
});

// Improve touch scrolling for tables
$(document).on('touchmove', '.table-responsive', function(e) {
  e.stopPropagation();
});

// Initialize chart instances storage
window.chartInstances = window.chartInstances || {};

// Chart timeframe functions
function updateDashboardTimeframe(timeframe) {
  // Update button states
  document.querySelectorAll('.chart-container .timeframe-btn').forEach(btn => {
    btn.classList.remove('active');
  });
  event.target.classList.add('active');
  
  // Reload chart with new timeframe
  if (window.currentDashboardAddress) {
    loadDashboardChart(window.currentDashboardAddress, timeframe);
  }
}

function updateStatsTimeframe(timeframe) {
  // Update button states
  document.querySelectorAll('.chart-container .timeframe-btn').forEach(btn => {
    btn.classList.remove('active');
  });
  event.target.classList.add('active');
  
  // Reload chart with new timeframe
  loadStatsChart(timeframe);
}

function updateDailyPaymentTimeframe(days) {
  // Update button states
  document.querySelectorAll('.chart-container .timeframe-btn').forEach(btn => {
    btn.classList.remove('active');
  });
  event.target.classList.add('active');
  
  // Update chart with new timeframe
  if (window.dailyPaymentChartData) {
    updateDailyPaymentChart(window.dailyPaymentChartData, days);
  }
}
</script>

